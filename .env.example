# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

SECRET_KEY=replace-with-50-char-random-string

# Environment: development | production
DJANGO_ENV=development

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (only used in production)
# For Docker: postgresql://simphantom:yourpassword@db:5432/simphantom
# For hosted DB: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Set to True only after SSL certs are in nginx/ssl/ and Nginx is serving HTTPS
SECURE_SSL_REDIRECT=False

# 5sim
FIVESIM_API_KEY=

# Paystack
PAYSTACK_SECRET=
PAYSTACK_PUBLIC_KEY=

# Bright Data (residential proxies)
BRIGHTDATA_API_KEY=
BRIGHTDATA_ZONE_NAME=
BRIGHTDATA_CUSTOMER_ID=
BRIGHTDATA_ZONE_PASS=

# Twilio (bulk SMS + phone lookup)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ESIMCard
ESIMCARD_API_TOKEN=

# Google OAuth (from Google Cloud Console → Credentials → OAuth 2.0 Client ID)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudflare Turnstile
CLOUDFLARE_TURNSTILE_SECRET_KEY=

# Brevo SMTP
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_FROM=noreply@simphantom.com
EMAIL_FROM_NAME=SimPhantom

# Admin notifications
ADMIN_NOTIFY_EMAIL=simphantom1@gmail.com
