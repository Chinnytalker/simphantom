# Environment & secrets — NEVER commit these
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual environment
.venv/
venv/
env/
ENV/

# Django
db.sqlite3
db.sqlite3-journal
staticfiles/
mediafiles/
*.log
server.log
server_err.log

# SSL certificates — never commit private keys
nginx/ssl/*.pem
nginx/ssl/*.key
nginx/ssl/*.crt

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

